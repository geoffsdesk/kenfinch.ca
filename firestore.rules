
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Rules for user-specific data (dashboard, tasks, valuations)
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Rules for admin access to user data
    match /users/{userId} {
        allow read: if request.auth != null && request.auth.uid == 'PUT_ADMIN_UID_HERE';
    }
    match /users/{userId}/valuations/{valuationId} {
         allow read: if request.auth != null && request.auth.uid == 'PUT_ADMIN_UID_HERE';
    }

    // Allow admin to read all contact submissions
    match /contacts/{contactId} {
      allow read: if request.auth != null && request.auth.uid == 'PUT_ADMIN_UID_HERE';
      allow create: if true;
    }

    // Allow anyone to create documents in the 'mail' collection to trigger emails
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if false; // Only backend processes should access this
    }

  }
}
