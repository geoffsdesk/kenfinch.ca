rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read and write to their own user document and subcollections.
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Admins (or a specific user) can read contact submissions.
    // For a real app, you would lock this down to a specific admin UID.
    match /contacts/{contactId} {
      allow read: if request.auth != null; // Or check for admin role
      allow create: if true; // Allow anyone to create a contact message
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
