
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the user is an administrator
    function isAdmin() {
      // In a real app, you would check a custom claim or a document in a separate 'admins' collection.
      // For this example, we'll assume a specific UID is the admin.
      // IMPORTANT: Replace 'YOUR_ADMIN_UID_HERE' with the actual UID of your admin user.
      return request.auth.uid == 'O1pS9kLTOxZq6c7y4Y9dJjE5e5B2';
    }

    // Rules for the 'users' collection
    match /users/{userId}/{document=**} {
      // Only the authenticated user can access their own documents
      allow read, write: if request.auth.uid == userId;
    }

    // Rules for the 'contacts' collection
    match /contacts/{contactId} {
      // Any user (even unauthenticated) can create a contact submission
      allow create;
      // Only the admin can read, update, or delete contact submissions
      allow read, update, delete: if isAdmin();
    }
    
    // Rules for the 'chatbot_logs' collection
    match /chatbot_logs/{logId} {
        // Any authenticated user can create a log entry (i.e., ask the bot a question)
        allow create: if request.auth != null;
        // Only the admin can read the logs
        allow read: if isAdmin();
        // Nobody can update or delete logs through the client
        allow update, delete: if false;
    }
  }
}
