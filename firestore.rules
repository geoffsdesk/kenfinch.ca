rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helpers
    function isAdmin() {
      // IMPORTANT: Replace this placeholder with your actual Admin User ID from Firebase Auth.
      return request.auth.uid == 'YOUR_ADMIN_UID_HERE';
    }
  
    // Rules for 'users' collection
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId || isAdmin();
    }
    
    // Rules for 'contacts' collection
    // Allow anyone to create (for the form), but only admin to read.
    match /contacts/{contactId} {
      allow create;
      allow read, write: if isAdmin();
    }

    // Rules for 'chatbot_logs' collection
    // Allow any authenticated user to create (log) a message.
    match /chatbot_logs/{logId} {
      allow create: if request.auth != null;
      // Allow only the admin to read the logs.
      allow read: if isAdmin();
    }
  }
}