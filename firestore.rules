rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Sellers can read/write their own data
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth.uid == userId;
    }
    
    // Admins can read all user data
    match /users/{userId} {
        allow read: if request.auth != null;
    }
     match /users/{userId}/{documents=**} {
        allow read: if request.auth != null;
    }

    // Anyone can submit the contact form
    // Admins can read the contacts
    match /contacts/{contactId} {
      allow create: if request.auth == null || request.auth != null;
      allow read: if request.auth != null;
    }

    // Authenticated users can write chat logs
    // Admins can read chat logs
    match /chatbot_logs/{logId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
    }
  }
}
