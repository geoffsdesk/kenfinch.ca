13:["$","li","li-4",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Schedule a Pre-Listing Home Inspection:"}]," An inspection can identify common issues in homes from the 90s/2000s builds typical in these areas (e.g., original windows, furnace/AC age). Fixing them now prevents them from becoming a negotiation point later."]}]
14:["$","li","li-5",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Engage a Real Estate Lawyer:"}]," Choose a lawyer experienced in Ontario real estate law and, ideally, one familiar with townhouse corporations."]}]
