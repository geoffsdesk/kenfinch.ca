1a:["$","ul","ul-2",{"className":"contains-task-list","children":["\n",["$","li","li-0",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Final Staging Implementation:"}]," The home should look like a model home—clean, inviting, and stylish."]}],"\n",["$","li","li-1",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Professional Photography & Videography:"}]," Essential for showcasing the lifestyle. Photos must be bright and wide; a video tour should highlight the proximity to local parks, trails, and amenities that are key selling features of River Oaks and West Oak Trails."]}],"\n",["$","li","li-2",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Prepare a \"Features & Upgrades\" Sheet:"}]," List all upgrades and highlight neighbourhood benefits like \"Steps to Sixteen Mile Creek Trail,\" \"Walk to Top-Rated Schools,\" or \"Low Monthly Maintenance Fees.\""]}],"\n",["$","li","li-3",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Plan for Showings:"}]," Create a simple plan to quickly tidy the house and manage pets during viewing times."]}],"\n"]}]
