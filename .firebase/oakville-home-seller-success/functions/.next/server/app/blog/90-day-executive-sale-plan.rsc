y",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Streamline Offer Negotiation:"}]," Your pre-listing inspection and strategic pricing should pave the way for clean, strong offers. Your agent will manage negotiations efficiently to secure favourable terms and a firm closing date."]}],"\n"]}]
