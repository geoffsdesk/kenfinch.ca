"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Launch a \"Coming Soon\" Campaign:"}]," Your agent will leverage their network and targeted digital ads to build anticipation among qualified buyers and top agents before the listing officially goes live."]}],"\n",["$","li","li-2",{"className":"task-list-item list-none relative pl-8 my-2","children":[["$","svg","input-0",{"ref":"$undefined","xmlns":"http://www.w3.org/2000/svg","width":24,"height":24,"viewBox":"0 0 24 24","fill":"none","stroke":"currentColor","strokeWidth":2,"strokeLinecap":"round","strokeLinejoin":"round","className":"lucide lucide-circle-check h-5 w-5 text-green-600 absolute left-0 top-1.5","children":[["$","circle","1mglay",{"cx":"12","cy":"12","r":"10"}],["$","path","dzmm74",{"d":"m9 12 2 2 4-4"}],"$undefined"]}]," ",["$","strong","strong-0",{"children":"Go Live with Targeted Advertising:"}]," On launch day, a multi-channel digital advertising campaign will go live, targeting potential buyers based on income, profession, and online behaviour across platforms like LinkedIn, Facebook, Instagram, and luxury real estate portals."]}],"\n"]}]
18:["$","h2","h2-3",{"children":"Phase 4: On The Market – Showings & Negotiation (Weeks 4-8)"}]
