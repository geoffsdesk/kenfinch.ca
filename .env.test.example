# ────────────────────────────────────────────────
# KenFinch.ca E2E Test Configuration
# Copy this to .env.test and fill in values
# ────────────────────────────────────────────────

# Base URL of the site to test (default: https://www.kenfinch.ca)
TEST_BASE_URL=https://www.kenfinch.ca

# ── Gmail API (for email delivery verification) ──
# Create OAuth2 credentials at: https://console.cloud.google.com/apis/credentials
# Enable Gmail API at: https://console.cloud.google.com/apis/library/gmail.googleapis.com
# Get refresh token at: https://developers.google.com/oauthplayground
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
GMAIL_CHECK_EMAIL=realtor@kenfinch.ca

# ── SendGrid (for failure email alerts) ──
# Uses same API key as the site's email sending
SENDGRID_API_KEY=
ALERT_EMAIL_TO=geoff.radian6@gmail.com
ALERT_EMAIL_FROM=alerts@kenfinch.ca

# ── Twilio (for SMS & WhatsApp failure alerts) ──
# Sign up at: https://www.twilio.com/try-twilio
# WhatsApp sandbox: https://www.twilio.com/docs/whatsapp/sandbox
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_FROM=+1XXXXXXXXXX
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ALERT_PHONE_TO=+1XXXXXXXXXX
